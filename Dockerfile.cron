FROM python:3.11-slim

WORKDIR /app
COPY requirements-cron.txt .
RUN pip install --no-cache-dir -r requirements-cron.txt

COPY src/ src/
COPY scripts/ scripts/

# Default command — overridden per service via Railway start command.
# Railway cron will start this container, run the command, and let it exit.
CMD ["python", "scripts/hourly_rss.py"]
