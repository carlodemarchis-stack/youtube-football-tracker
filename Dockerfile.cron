FROM python:3.11-slim

WORKDIR /app
COPY requirements-cron.txt .
RUN pip install --no-cache-dir -r requirements-cron.txt

COPY src/ src/
COPY scripts/ scripts/

# Run the internal scheduler — handles hourly/daily/weekly jobs itself.
# No Railway cron needed; this container stays alive and manages timing.
CMD ["python", "scripts/scheduler.py"]
