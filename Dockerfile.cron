FROM python:3.11-slim

WORKDIR /app
COPY requirements-cron.txt .
RUN pip install --no-cache-dir -r requirements-cron.txt

COPY src/ src/
COPY scripts/ scripts/

# Keep container alive so Railway cron can invoke against it.
# The actual work runs via the cron schedule's start command override.
CMD ["tail", "-f", "/dev/null"]
