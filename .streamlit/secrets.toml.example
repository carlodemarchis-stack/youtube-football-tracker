# Copy to .streamlit/secrets.toml locally, or paste into Streamlit Cloud
# Settings → Secrets. Do NOT commit the real secrets.toml.

SUPABASE_URL = "https://<project>.supabase.co"
# Public web app uses the ANON key (subject to Row-Level Security). All
# public/login-gated views read this. Browser never sees it directly
# (Streamlit is server-side), but using anon means RLS policies actually
# apply when you enable them on the database.
SUPABASE_KEY = "<anon-key>"
# Admin pages (Refresh Data / Channel Management / User Management) use
# the SERVICE-role key — bypasses RLS so admin writes still work after
# the anon-key surface is locked down. Pages are gated by require_admin().
SUPABASE_SERVICE_KEY = "<service-role-key>"
YOUTUBE_API_KEY = "<google-api-key>"

[app]
anthropic_api_key = "sk-ant-..."

# Google OAuth for st.login() — required on Streamlit Cloud
[auth]
redirect_uri = "https://<your-app>.streamlit.app/oauth2callback"
cookie_secret = "<random-hex: python -c 'import secrets; print(secrets.token_hex(32))'>"
client_id = "<google-oauth-client-id>"
client_secret = "<google-oauth-client-secret>"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
