# Copy to .streamlit/secrets.toml locally, or paste into Streamlit Cloud
# Settings → Secrets. Do NOT commit the real secrets.toml.

SUPABASE_URL = "https://<project>.supabase.co"
SUPABASE_KEY = "<service-role-or-anon-key>"
YOUTUBE_API_KEY = "<google-api-key>"

[app]
anthropic_api_key = "sk-ant-..."

# Google OAuth for st.login() — required on Streamlit Cloud
[auth]
redirect_uri = "https://<your-app>.streamlit.app/oauth2callback"
cookie_secret = "<random-hex: python -c 'import secrets; print(secrets.token_hex(32))'>"
client_id = "<google-oauth-client-id>"
client_secret = "<google-oauth-client-secret>"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
